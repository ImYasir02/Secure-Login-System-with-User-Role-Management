# /etc/mysql/mariadb.conf.d/50-secure-login.cnf
[mysqld]
port = 3307
bind-address = 127.0.0.1
skip_name_resolve = 1
local_infile = 0
symbolic-links = 0
max_connections = 200
character-set-server = utf8mb4
collation-server = utf8mb4_unicode_ci

# Logging / monitoring
slow_query_log = 1
slow_query_log_file = /var/log/mysql/mariadb-slow.log
long_query_time = 1
log_error = /var/log/mysql/error.log

# TLS (enable if remote DB clients are needed)
# require_secure_transport = ON
